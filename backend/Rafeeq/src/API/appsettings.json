{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "RateLimiter": {
    "Auth": {
      "PermitLimit": 5,
      "Window": "00:01:00"
    },
    "Global": {
      "PermitLimit": 60,
      "Window": "00:01:00"
    }
  },

  "RefreshTokenCleanup": {
    "Interval": "9:00:00"
  },
  
  "AllowedHosts": "*",
  
  "JwtSettings": {
    "Issuer": "https://api.rafeeq.live/",
    "Audience": "https://api.rafeeq.live/",
    "AccessTokenExpirationInHours": 6,
    "RefreshTokenExpirationInDays": 7,
    "AccessTokenExpirationForAdminInMinutes": 90,
    "RefreshTokenExpirationForAdminInHours": 30,
    "TokenLifespanHours": 2
  },

  "EmailSettings": {
    "EnableSsl": true,
    "FromName": "Rafeeq"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    }
  },

  "FileUpload": {
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [".jpg", ".jpeg", ".png", ".webp"],
    "MaxFilesPerRequest": 10,
    "EnableDuplicateDetection": true,
    "EnableImageResize": true,
    "MaxWidthPx": 2048,
    "MaxHeightPx": 2048
  },
  
  "Cloudinary": {
    "UploadFolder": "rafeeq/uploads",
    "SignedUrlExpirySeconds": 3600
  },

  "ImageScannerService": {
    "BaseUrl": "http://127.0.0.1:8000",
    "ScanEndpoint": "/search",
    "ImageFieldName": "file",
    "TimeoutSeconds": 30
  },

  "TripPlannerService": {
    "BaseUrl": "http://127.0.0.1:8000",
    "PlanEndpoint": "/generate-trip",
    "TimeoutSeconds": 30
  }
}
