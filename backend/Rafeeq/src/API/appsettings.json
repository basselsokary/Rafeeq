{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/rafeeq-.txt",
          "rollingInterval": "Day",
          "rollOnFileSizeLimit": true
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithThreadId"]
  },

  "RateLimiter": {
    "Auth": {
      "PermitLimit": 5,
      "Window": "00:01:00"
    },
    "Global": {
      "PermitLimit": 60,
      "Window": "00:01:00"
    }
  },
  "RefreshTokenCleanup": {
    "Interval": "9:00:00"
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "AccessTokenExpirationInMinutes": 360,
    "RefreshTokenExpirationInHours": 7,
    "AccessTokenExpirationForAdminInMinutes": 120,
    "RefreshTokenExpirationForAdminInHours": 7,
    "TokenLifespanHours": 2
  },
  "EmailSettings": {
    "EnableSsl": true,
    "FromName": "Rafeeq"
  },
  "FileUpload": {
    "MaxFileSizeBytes": 5242880,
    "AllowedExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp"
    ],
    "MaxFilesPerRequest": 10,
    "EnableDuplicateDetection": true,
    "EnableImageResize": true,
    "MaxWidthPx": 2048,
    "MaxHeightPx": 2048
  },
  "Cloudinary": {
    "UploadFolder": "rafeeq/uploads",
    "SignedUrlExpirySeconds": 3600
  },
  "ImageScannerService": {
    "ScanEndpoint": "/predict",
    "ImageFieldName": "file",
    "TimeoutSeconds": 30
  },
  "TripPlannerService": {
    "PlanEndpoint": "/generate-multi-day-trip",
    "TimeoutSeconds": 30
  }
}